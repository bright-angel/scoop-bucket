{
    "version": "4.0.1",
    "description": "Weaponized web shell.(Scoop bucket by arch3rpro)",
    "notes": [
        "【工具类型】: 安全测试工具",
        "【主要功能】: 多功能WebShell工具，支持生成和管理WebShell",
        "【适用场景】: WebShell管理、权限维持、渗透测试",
        "【技术特点】: Python开发，命令行工具，支持多种功能模块"
    ],
    "homepage": "https://github.com/epinna/weevely3",
    "license": "GPL-3.0",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/epinna/weevely3/archive/refs/heads/master.zip",
    "pre_install": "Set-Content \"$dir\\weevely.bat\" '@pushd %~dp0\n@uv run python \"weevely.py\" %*\n@popd' -Encoding Ascii",
    "post_install": [
        "Move-Item -Path \"$dir\\weevely3-master\\*\" -Destination \"$dir\\\"",
        "Remove-Item \"$dir\\weevely3-master\" -Force -Recurse",
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\"",
        "uv venv \"$dir\\.venv\"",
        "uv pip install pyreadline3 --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "weevely.bat"
}
