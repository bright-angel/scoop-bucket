{
    "version": "master",
    "description": "XSS'OR - Hack with JavaScript.(Scoop bucket by arch3rpro)",
    "notes": [
        "【工具类型】: 安全测试工具",
        "【主要功能】: XSS漏洞测试工具，支持JavaScript payload生成和测试",
        "【适用场景】: XSS漏洞测试、渗透测试、安全评估",
        "【技术特点】: Python2开发，Web界面，支持多种XSS payload"
    ],
    "homepage": "https://github.com/evilcos/xssor2",
    "license": "BSD-2-Clause",
    "suggest": {
        "python": [
            "miniconda3"
        ]
    },
    "url": "https://github.com/evilcos/xssor2/archive/refs/heads/master.zip",
    "hash": "",
    "extract_dir": "xssor2-master",
    "pre_install": [
        "Set-Content \"$dir\\xssor2.bat\" '@pushd %~dp0",
        "@call activate python2env",
        "@python manage.py runserver 0.0.0.0:8000 %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "& cmd /c \"call activate python2env && pip install -r $dir\\requirement.txt\""
    ],
    "bin": "xssor2.bat"
}
