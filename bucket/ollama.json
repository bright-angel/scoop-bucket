{
    "version": "0.30.4",
    "description": "Get up and running with large language models locally.",
    "homepage": "https://ollama.com/",
    "license": "MIT",
    "notes": [
        "【工具类型】: AI工具",
        "【主要功能】: 本地运行大型语言模型的工具，支持多种开源模型",
        "【适用场景】: AI开发、本地推理、模型测试",
        "【技术特点】: Windows可执行文件，命令行工具，支持64位和ARM64"
    ],
    "suggest": {
        "Ollama Full": "extras/ollama-full"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.4/ollama-windows-amd64.zip",
            "hash": "11411244d4f92b75d7431eeda1a572d5df550d992b6fbdae63a6e5ba932f7633"
        },
        "arm64": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.4/ollama-windows-arm64.zip",
            "hash": "57df5854ff65389d3cee31e674747c94e810f04bd3c3eb5abd25dfd66f12e1b9"
        }
    },
    "bin": "ollama.exe",
    "persist": "models",
    "env_set": {
        "OLLAMA_MODELS ": "$dir\\models"
    },
    "checkver": {
        "github": "https://github.com/ollama/ollama"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sum.txt"
        }
    }
}
