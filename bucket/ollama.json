{
    "version": "0.30.7",
    "description": "Get up and running with large language models locally.",
    "homepage": "https://ollama.com/",
    "license": "MIT",
    "notes": [
        "【工具类型】: AI工具",
        "【主要功能】: 本地运行大型语言模型的工具，支持多种开源模型",
        "【适用场景】: AI开发、本地推理、模型测试",
        "【技术特点】: Windows可执行文件，命令行工具，支持64位和ARM64"
    ],
    "suggest": {
        "Ollama Full": "extras/ollama-full"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.7/ollama-windows-amd64.zip",
            "hash": "ce8169abfe48e05a865958391729ff14f297513ae67fdb4ec7b11a37b9c5b715"
        },
        "arm64": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.7/ollama-windows-arm64.zip",
            "hash": "d09d66c61482b667a4c1e7bf1e58f15baf09f740e329a919b56ea5bcfd10eb72"
        }
    },
    "bin": "ollama.exe",
    "persist": "models",
    "env_set": {
        "OLLAMA_MODELS ": "$dir\\models"
    },
    "checkver": {
        "github": "https://github.com/ollama/ollama"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sum.txt"
        }
    }
}
