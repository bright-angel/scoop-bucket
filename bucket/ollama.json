{
    "version": "0.30.11",
    "description": "Get up and running with large language models locally.",
    "homepage": "https://ollama.com/",
    "license": "MIT",
    "notes": [
        "【工具类型】: AI工具",
        "【主要功能】: 本地运行大型语言模型的工具，支持多种开源模型",
        "【适用场景】: AI开发、本地推理、模型测试",
        "【技术特点】: Windows可执行文件，命令行工具，支持64位和ARM64"
    ],
    "suggest": {
        "Ollama Full": "extras/ollama-full"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.11/ollama-windows-amd64.zip",
            "hash": "43d534c10040ea676c99af19836377a315daa8cb3bb6c3d9d609b4c23dd37b88"
        },
        "arm64": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.11/ollama-windows-arm64.zip",
            "hash": "51265dae69392a90b7a346d61babef2bd5df4fff2aa8b4e3c8d73e2fbb87dae1"
        }
    },
    "bin": "ollama.exe",
    "persist": "models",
    "env_set": {
        "OLLAMA_MODELS ": "$dir\\models"
    },
    "checkver": {
        "github": "https://github.com/ollama/ollama"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sum.txt"
        }
    }
}
