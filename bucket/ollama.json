{
    "version": "0.30.9",
    "description": "Get up and running with large language models locally.",
    "homepage": "https://ollama.com/",
    "license": "MIT",
    "notes": [
        "【工具类型】: AI工具",
        "【主要功能】: 本地运行大型语言模型的工具，支持多种开源模型",
        "【适用场景】: AI开发、本地推理、模型测试",
        "【技术特点】: Windows可执行文件，命令行工具，支持64位和ARM64"
    ],
    "suggest": {
        "Ollama Full": "extras/ollama-full"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.9/ollama-windows-amd64.zip",
            "hash": "6d83cbe1db06ec659e7f47c0897318d2093128bcbb7c5d140c142e71d65f991f"
        },
        "arm64": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.9/ollama-windows-arm64.zip",
            "hash": "1679bfc1137a3ded3c2177d54c99ca96cd24a006197f993a889877b8379cdec7"
        }
    },
    "bin": "ollama.exe",
    "persist": "models",
    "env_set": {
        "OLLAMA_MODELS ": "$dir\\models"
    },
    "checkver": {
        "github": "https://github.com/ollama/ollama"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sum.txt"
        }
    }
}
