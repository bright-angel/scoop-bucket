{
    "version": "0.30.0",
    "description": "Get up and running with large language models locally.",
    "homepage": "https://ollama.com/",
    "license": "MIT",
    "notes": [
        "【工具类型】: AI工具",
        "【主要功能】: 本地运行大型语言模型的工具，支持多种开源模型",
        "【适用场景】: AI开发、本地推理、模型测试",
        "【技术特点】: Windows可执行文件，命令行工具，支持64位和ARM64"
    ],
    "suggest": {
        "Ollama Full": "extras/ollama-full"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.0/ollama-windows-amd64.zip",
            "hash": "c869517b0852372d694c2978564a73b5aa70eaafe96d73aab1783971f7c2f9d2"
        },
        "arm64": {
            "url": "https://github.com/ollama/ollama/releases/download/v0.30.0/ollama-windows-arm64.zip",
            "hash": "81385e9bf4eb644e6640fb1eaf3d9340770f8bf71c936ec5b7352405373282a9"
        }
    },
    "bin": "ollama.exe",
    "persist": "models",
    "env_set": {
        "OLLAMA_MODELS ": "$dir\\models"
    },
    "checkver": {
        "github": "https://github.com/ollama/ollama"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/ollama/ollama/releases/download/v$version/ollama-windows-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sum.txt"
        }
    }
}
