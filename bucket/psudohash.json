{
    "version": "master",
    "description": "Generates millions of keyword-based password mutations in seconds.",
    "homepage": "https://github.com/t3l3machus/psudohash",
    "license": "MIT",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/t3l3machus/psudohash/archive/refs/heads/main.zip",
    "hash": "",
    "extract_dir": "psudohash-main",
    "pre_install": [
        "Set-Content \"$dir\\psudohash.bat\" '@pushd %~dp0",
        "@uv run python \"psudohash.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "bin": "psudohash.bat",
    "notes": [
        "【工具类型】: 密码破解工具",
        "【主要功能】: 基于关键词的密码变异生成工具，每秒生成数百万个密码变体",
        "【适用场景】: 密码破解、字典生成、渗透测试",
        "【技术特点】: Python开发，需要miniconda3环境，命令行工具"
    ]
}
