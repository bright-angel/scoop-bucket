{
    "version": "mian",
    "description": "Multiplatform Python WebShell.(Scoop bucket by arch3rpro)",
    "homepage": "https://github.com/JoelGMSec/PyShell",
    "license": "GPL-3.0",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/JoelGMSec/PyShell/archive/refs/heads/main.zip",
    "pre_install": "Set-Content \"$dir\\pyshell.bat\" '@pushd %~dp0\n@uv run python \"pyshell.py\" %*\n@popd' -Encoding Ascii",
    "post_install": [
        "Move-Item -Path \"$dir\\pyshell-main\\*\" -Destination \"$dir\\\"",
        "Remove-Item \"$dir\\pyshell-main\" -Force -Recurse",
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\"",
        "uv venv \"$dir\\.venv\"",
        "uv pip install pyreadline3 --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "pyshell.bat",
    "notes": [
        "【工具类型】: Python工具",
        "【主要功能】: Multiplatform Python WebShell.(Scoop bucket by arch3rpro)",
        "【适用场景】: 根据描述推断的适用场景",
        "【技术特点】: 基于Python开发，需Python环境"
    ]
}
